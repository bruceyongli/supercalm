# Supercalm configuration — copy to a local env file for your setup and source it before `npm start`.
# EVERYTHING here has a working default in src/config.js; you only need to set what differs for you.
# This file documents the setup/infra knobs. There are ~130 more fine-tuning knobs (timeouts, limits,
# per-agent model/effort defaults) — all optional, all with defaults — see src/config.js.

# ── Core ────────────────────────────────────────────────────────────────────
AIOS_PORT=8793                 # HTTP port the server listens on (127.0.0.1)
AIOS_HOST=127.0.0.1            # bind address (keep loopback; expose via a reverse proxy / Tailscale Serve)
# AIOS_DATA=./data             # data dir (sqlite, per-session logs, vapid keys) — gitignored
# AIOS_SELF_URL=https://your-node.your-tailnet.ts.net/aios   # public base URL (web-push, links)

# ── Voice device (optional — Spark: Whisper STT + Kokoro TTS) ────────────────
# Supercalm reaches this device by IP + SNI (its MagicDNS may not resolve on the server). All optional; voice
# is disabled gracefully if unset. Replace with YOUR device's tailnet IP + hostname.
# SPARK_IP=100.x.x.x
# SPARK_HOST=spark.your-tailnet.ts.net
# SPARK_LAN_IP=192.168.x.x     # optional same-LAN IP (lower latency)

# ── Model proxy fleet (optional — local OpenAI/Anthropic-compatible proxies) ──
# Supercalm consumes a local multi-model proxy fleet for summaries / voice brain / supervisor. If you don't run
# one, these features degrade gracefully. The fleet gates /v1/* behind a key; Supercalm auto-reads it from the
# proxies' launchd plists, or set it explicitly here.
# AIOS_PROXY_KEY=              # the fleet API key (Bearer) for /v1/* calls
# AIOS_SUMMARY_PORT=8789       # port serving the summary model
# AIOS_SUMMARY_MODEL=claude-haiku-4-5
# AIOS_VOICE_CHAIN=            # comma-separated model fallback chain for the voice brain

# ── Claude session auth routing (optional) ───────────────────────────────────
# AIOS_CLAUDE_BASE_URL=        # pin a proxy URL; '' forces the CLI's own /login (see src/auth/)

# ── External binaries (optional — auto-detected on PATH if unset) ────────────
# AIOS_CHROME=                 # path to Chrome/Chromium (supervisor screenshots, headless verify)
# AIOS_FFMPEG=ffmpeg           # ffmpeg (voice transcode)
# AIOS_AGY_BIN=agy             # the `agy` CLI binary, if named differently

# ── Antigravity (Google) auth (optional) ──
# Only if you use the antigravity provider; the installed-app OAuth client from the antigravity CLI.
# AG_CLIENT_ID=
# AG_CLIENT_SECRET=
