# ─────────────────────────────────────────────────────────────────────────────
#  Supercalm configuration
#  Copy this file to  data/aios.env  (gitignored) and set only what differs for you.
#      cp .env.example data/aios.env
#  EVERYTHING has a working default in src/config.js — an empty data/aios.env is valid.
#  A value already in the real environment always wins over this file.
#  Full reference: docs/CONFIGURATION.md
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
AIOS_PORT=8793                 # HTTP port (binds loopback)
AIOS_HOST=127.0.0.1            # bind address — keep loopback; expose via a reverse proxy / Tailscale Serve
# AIOS_DATA=./data             # data dir: sqlite, per-session logs, vapid keys (gitignored)
# AIOS_SELF_URL=https://your-node.example.ts.net/aios   # public base URL used in web-push + links

# ── System binaries (auto-resolved across common locations; set only if elsewhere) ──
# AIOS_TMUX=tmux               # required. macOS: `brew install tmux`. Linux: apt/dnf install tmux
# AIOS_FFMPEG=ffmpeg           # needed for voice (audio transcode). `brew install ffmpeg` / apt install ffmpeg
# AIOS_CHROME=                 # Chrome/Chromium path for supervisor screenshots + headless verify (optional)
# AIOS_TOOL_PATH=/opt/homebrew/bin:/usr/local/bin:/usr/bin:$HOME/.local/bin   # PATH used to find the agent CLIs
# AIOS_AGY_BIN=agy             # the `agy` CLI binary name/path, if different

# ── Coding-agent auth (no env needed) ────────────────────────────────────────
# claude / codex / agy authenticate through THEIR OWN CLIs (run `claude`, `codex`, `agy` once and log in),
# or via the in-app Auth page (/aios/auth). Supercalm never stores their passwords. See docs/CONFIGURATION.md.

# ── External model proxy (optional — powers summaries, the voice brain, and the supervisor) ──
# Supercalm can use a local OpenAI/Anthropic-compatible multi-model proxy. Without one, those features
# degrade gracefully (agents still run; you just answer more yourself).
# AIOS_PROXY_KEY=              # Bearer token IF your proxy requires one. Leave blank for a keyless local proxy.
#                             #   (auto-read from a local proxy's launchd plist when present; set here to override)
# AIOS_DEFAULT_PROXY_PORT=8789 # port of your default chat proxy
# AIOS_SUMMARY_PORT=8789       # port serving the cheap "summarize the screen" model
# AIOS_SUMMARY_MODEL=claude-haiku-4-5
# AIOS_VOICE_CHAIN=            # comma-separated model fallback chain for the voice brain (first that answers wins)
# AIOS_SUPERVISOR_DEFAULT_MODEL=gemini-pro-agent    # default model the Supervisor agent reasons with (vision-capable)
# AIOS_CLAUDE_BASE_URL=        # pin claude sessions to a proxy URL; '' forces the claude CLI's own login (see src/auth/)

# ── Voice: Speech-to-text + Text-to-speech (optional) ────────────────────────
# Voice uses an external device ("Spark": Whisper STT + Kokoro/Qwen TTS). Reached by IP + SNI because its
# MagicDNS often won't resolve on the server. Unset = voice disabled (text still works everywhere).
# SPARK_IP=100.64.x.x          # your voice device's Tailscale IP (CGNAT range 100.64–100.127.x.x)
# SPARK_HOST=spark.example.ts.net   # its MagicDNS name (used as TLS SNI + Host header)
# SPARK_PORT=443
# SPARK_LAN_IP=192.168.1.50    # optional same-LAN IP for lower latency
# AIOS_TTS_BACKEND=spark       # spark | local   (local = macOS `say`, no device needed)
# AIOS_TTS_ENGINE=kokoro       # kokoro | qwen   (Spark TTS engine)
# AIOS_TTS_VOICE=af_heart      # TTS voice id
# AIOS_TTS_PORT=               # Spark TTS port override
# AIOS_LOCAL_TTS_VOICE=        # macOS `say` voice for the local fallback
# AIOS_STT_POLISH=false        # true = grammar-clean the Whisper transcript (default: raw, better for code)

# ── Antigravity (Google) auth (optional — only if you use the `agy` proxy provider) ──
# The installed-app OAuth client from the antigravity CLI. Supply your own; there is no default.
# AG_CLIENT_ID=
# AG_CLIENT_SECRET=

# ── Session defaults (overridable per-session in the New-Session UI) ─────────
# AIOS_AUTONOMY=full           # ask | auto | full   (full = agents run hands-off)
# AIOS_CLAUDE_MODEL=opus
# AIOS_CODEX_MODEL=gpt-5.5
# AIOS_AGY_MODEL=gemini-pro-agent

# ── Update check (in-app "new release" toast) ────────────────────────────────
# The server asks GitHub for the latest release ~every 12h and the UI shows an update toast when one is
# newer than the running build. One anonymous HTTPS request; no telemetry.
# AIOS_UPDATE_CHECK=1          # 0 disables the check entirely
# AIOS_UPDATE_REPO=bruceyongli/supercalm   # point forks at their own repo
# AIOS_UPDATE_CHECK_MS=43200000            # check interval (ms)

# ── Notifications & misc ─────────────────────────────────────────────────────
# AIOS_PUSH_SUBJECT=mailto:you@example.com   # VAPID contact for web-push (a mailto: or https: URI)
# AIOS_IDLE_WAIT=4500          # ms of no screen change before a session is deemed "waiting"
# AIOS_SUBMIT_DELAY=320        # ms pause before pressing Enter after pasting text into an agent TUI
