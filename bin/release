#!/usr/bin/env bash
# Cut a Supercalm release (maintainer tool): bump the version (bin/version: package.json -> commit ->
# annotated tag) -> push with tags -> create the GitHub Release (needs GITHUB_TOKEN; skipped without it,
# and installs still learn about the release via the package.json fallback in src/update_check.js).
#
# Usage:  bin/release [patch|minor|major|X.Y.Z]
set -euo pipefail
cd "$(dirname "$0")/.."

[ -z "$(git status --porcelain)" ] || { echo "bin/release: commit or stash local changes first." >&2; exit 1; }
# Releases cut from a feature branch never reach origin/main — installs and bin/update see nothing
# (learned live: v0.3.19 was tagged on feat/phone and the live box reported "already up to date").
BR0="$(git rev-parse --abbrev-ref HEAD)"
if [ "$BR0" != "main" ] && [ "${RELEASE_BRANCH_OK:-0}" != "1" ]; then
  echo "bin/release: on '$BR0', not main — merge first (or RELEASE_BRANCH_OK=1 to force)." >&2; exit 1
fi
node scripts/scan-secrets.mjs >/dev/null   # belt-and-suspenders before anything is tagged for the public

# At release cadence, a red build must not reach the public: the full suite gates every release.
# RELEASE_SKIP_TESTS=1 for emergencies only (the tag will still be CI-checked on GitHub).
if [ "${RELEASE_SKIP_TESTS:-0}" != "1" ]; then
  echo "==> running the test suite (RELEASE_SKIP_TESTS=1 to skip)"
  npm test >/dev/null 2>&1 || { echo "bin/release: test suite FAILED — not releasing. (npm test for details)" >&2; exit 1; }
fi

# GitHub Release token: env GITHUB_TOKEN wins; otherwise auto-read GITHUB_PAT_AIOS / GITHUB_TOKEN
# from ~/.dev.vars so the Release object (which update toasts poll) is created without manual steps.
if [ -z "${GITHUB_TOKEN:-}" ] && [ -f "$HOME/.dev.vars" ]; then
  GITHUB_TOKEN="$(sed -n 's/^\(export \)\{0,1\}GITHUB_PAT_AIOS=//p; s/^\(export \)\{0,1\}GITHUB_TOKEN=//p' "$HOME/.dev.vars" | head -1 | tr -d '\"' )"
  export GITHUB_TOKEN
fi

# Persist checkpoint execution (auditable later — supervisors kept asking for proof the gates RAN):
EVIDENCE="data/release-evidence.log"
mkdir -p data
printf '%s release-start branch=%s head=%s secret-scan=clean suite=%s\n' \
  "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$BR0" "$(git rev-parse --short HEAD)" \
  "$([ "${RELEASE_SKIP_TESTS:-0}" = "1" ] && echo SKIPPED || echo green)" >> "$EVIDENCE"

NEW="$(bin/version "${1:-patch}")"
BR="$(git rev-parse --abbrev-ref HEAD)"
echo "==> pushing $BR + tags"
git push origin "$BR" --follow-tags

ORIGIN="$(git remote get-url origin)"
REPO="$(echo "$ORIGIN" | sed -E 's#(git@github.com:|https://github.com/)##; s#\.git$##')"
if [ -n "${GITHUB_TOKEN:-}" ] && [ -n "$REPO" ]; then
  echo "==> creating GitHub release v$NEW on $REPO"
  curl -sS -X POST "https://api.github.com/repos/$REPO/releases" \
    -H "authorization: Bearer $GITHUB_TOKEN" -H "accept: application/vnd.github+json" \
    -d "{\"tag_name\":\"v$NEW\",\"name\":\"v$NEW\",\"generate_release_notes\":true}" \
    | node -e "let s='';process.stdin.on('data',d=>s+=d).on('end',()=>{const j=JSON.parse(s);console.log(j.html_url?('==> release: '+j.html_url):('release API: '+(j.message||s.slice(0,200))))})"
else
  echo "==> no GITHUB_TOKEN — tag pushed; create the GitHub Release from the tags page if wanted."
fi
# Mark THIS version STABLE (config.js RELEASE_CHANNEL reads it at boot; the restart below reboots into it).
# The new-version toast filters on this: users on "stable only" get the reload toast for a blessed release
# like this, but NOT for routine bin/deploy auto-deploys (which never write this marker). Written before the
# restart so the rebooted server serves channel=stable at /api/version.
printf '{"version":"%s","channel":"stable","at":"%s"}\n' "$NEW" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" > data/release_channel.json
echo "==> marked v$NEW as a STABLE release (data/release_channel.json)"
# If THIS checkout is what the local service runs, restart it so the release goes live here too
# (same scoped check as bin/update — never restart a service that runs a different clone).
DIR="$(pwd)"
PLIST="$HOME/Library/LaunchAgents/ai.aios.server.plist"
UNIT="$HOME/.config/systemd/user/supercalm.service"
if [ "$(uname)" = "Darwin" ] && [ -f "$PLIST" ] && grep -q "<string>$DIR/src/server.js</string>" "$PLIST"; then
  launchctl kickstart -k "gui/$(id -u)/ai.aios.server" && echo "==> restarted local service on v$NEW"
elif [ -f "$UNIT" ] && grep -q "WorkingDirectory=$DIR" "$UNIT" && command -v systemctl >/dev/null 2>&1; then
  systemctl --user restart supercalm.service && echo "==> restarted local service on v$NEW"
fi
printf '%s released v%s tag=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$NEW" "$(git rev-parse --short "v$NEW")" >> "$EVIDENCE"
echo "==> released v$NEW"
