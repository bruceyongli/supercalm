#!/usr/bin/env bash
# Deploy Supercalm: bump the release version, push to gitlab, pull on host, restart the service.
# Git ONLY — no rsync. host's ~/aios is a real git checkout tracking origin/main
# (host's SSH key is registered with the gitlab project), so updates apply via pull.
#
# EVERY deploy increments the release version (the must-follow workflow — see CLAUDE.md "Release
# versioning"). The single source of truth is package.json; bin/version bumps it + package-lock.json,
# commits "release: vX.Y.Z", and tags. After restart the server serves the new version and open
# browsers get the bottom-left new-version toast on their next poll.
#
# Usage:  bin/deploy [patch|minor|major|X.Y.Z]   (default: patch)
set -euo pipefail
HOST="${AIOS_HOST:-host}"
LEVEL="${1:-patch}"
cd "$(dirname "$0")/.."

if ! git remote 2>/dev/null | grep -qx origin; then
  echo "error: no git 'origin' remote. Add it first:" >&2
  echo "  git remote add origin git@github.com:YOUR-ORG/aios.git   # your fork/remote" >&2
  exit 1
fi
BR="$(git branch --show-current)"

# Are we running ON the deploy target itself? (Dogfooding: an agent on host edits this very repo, which
# IS ~/aios and runs the launchd service — and host can't ssh to itself.) If so, the local checkout is
# the one we update, so skip the ssh hop and restart locally.
ON_HOST=0
if [ "$(pwd -P)" = "$(cd "$HOME/aios" 2>/dev/null && pwd -P || echo /nonexistent)" ] \
   && launchctl print "gui/$(id -u)/ai.aios.server" >/dev/null 2>&1; then
  ON_HOST=1
fi

# Clean tree required: the auto-bump always creates a pushable "release:" commit, and only COMMITTED
# work reaches host. Without this guard a deploy could look successful while uncommitted edits are
# silently left behind. Commit (or stash) your work first.
if [ -n "$(git status --porcelain)" ]; then
  echo "error: working tree is not clean — commit or stash your changes first." >&2
  echo "       bin/deploy adds only the version bump, and pushes only committed work." >&2
  exit 1
fi

# Deploy boundary (multi-agent safety): the live service ships origin/main from the canonical checkout.
# A parallel agent working in a linked git worktree on a feature branch must NOT deploy. These guards
# block that without affecting a normal main-checkout deploy on any machine.
if [ "${AIOS_NO_DEPLOY:-}" = "1" ]; then
  echo "error: AIOS_NO_DEPLOY=1 — deploys are disabled in this session." >&2
  exit 1
fi
if [ "$(git rev-parse --git-dir 2>/dev/null)" != "$(git rev-parse --git-common-dir 2>/dev/null)" ]; then
  echo "error: refusing to deploy from a linked git worktree." >&2
  echo "       Deploy only from the canonical main checkout (e.g. ~/aios), not a worktree." >&2
  exit 1
fi
if [ "$BR" != "main" ] && [ "${AIOS_ALLOW_BRANCH_DEPLOY:-}" != "1" ]; then
  echo "error: refusing to deploy from branch '$BR' (expected 'main')." >&2
  echo "       Deploys ship origin/main to the live service — merge to main first," >&2
  echo "       or set AIOS_ALLOW_BRANCH_DEPLOY=1 to override intentionally." >&2
  exit 1
fi

# Cross-process deploy lock (Finding 1: prevent a concurrent deploy — manual OR the autonomous pipeline,
# which also runs THIS script — from clobbering each other's push mid-restart). An exclusive flock on an
# inherited FD: the lock is held for this whole script (sync→bump→push→restart) and KERNEL-RELEASED when the
# process exits or dies, so there is no stale-lock file to ever delete. A second deploy WAITS (up to 5 min).
# FAIL-OPEN by design: if the lock mechanism can't run (no python3/flock, unwritable path), deploy proceeds
# exactly as before — the lock is an optimization; the real safety is the exact-SHA ff-abort + the pipeline's
# served-SHA HELD. macOS has no flock(1), so fall back to a fcntl.flock on the inherited FD via python3.
LOCKFILE="${AIOS_DEPLOY_LOCK:-$HOME/.local/share/aios/deploy.lock}"
if mkdir -p "$(dirname "$LOCKFILE")" 2>/dev/null && exec 9>"$LOCKFILE" 2>/dev/null; then
  if command -v flock >/dev/null 2>&1; then
    if flock -w 300 9; then echo "==> deploy lock acquired"; else echo "error: another deploy holds the lock ($LOCKFILE) — waited 5 min. Retry once it frees." >&2; exit 1; fi
  elif command -v python3 >/dev/null 2>&1; then
    python3 - 9 <<'PYLOCK'
import fcntl, sys, time
fd = int(sys.argv[1]); deadline = time.time() + 300
while True:
    try:
        fcntl.flock(fd, fcntl.LOCK_EX | fcntl.LOCK_NB); sys.exit(0)   # held via the parent shell's FD
    except BlockingIOError:
        if time.time() > deadline: sys.exit(2)
        time.sleep(1)
    except Exception:
        sys.exit(3)
PYLOCK
    rc=$?
    if [ "$rc" = 0 ]; then echo "==> deploy lock acquired"
    elif [ "$rc" = 2 ]; then echo "error: another deploy holds the lock ($LOCKFILE) — waited 5 min. Retry once it frees." >&2; exit 1
    else echo "==> deploy lock unavailable (fcntl rc=$rc) — proceeding without it (fail-open)"; fi
  else
    echo "==> no flock/python3 — proceeding without the deploy lock (fail-open)"
  fi
else
  echo "==> deploy lock file unavailable — proceeding without it (fail-open)"
fi

# Security checkpoint (operator doctrine: before any push to the PUBLIC repo, scan for credentials, personal
# data, or sensitive config). Run it EXPLICITLY here — independent of the git pre-commit hook (core.hooksPath),
# which requires `bin/install-hooks` and can be bypassed — so a release can never ship a secret even from a
# checkout without hooks installed. Aborts the deploy before anything is bumped, committed, or pushed.
echo "==> security checkpoint (credentials / private-data scan)"
if ! node scripts/scan-secrets.mjs; then
  echo "error: security checkpoint FAILED — credentials/private data detected. Deploy aborted; nothing pushed." >&2
  exit 1
fi

# Fast-forward to origin before bumping. Every deploy adds a release commit, so deploying from two
# checkouts of the same branch would otherwise diverge and fail --ff-only. Deploy from ONE machine.
echo "==> sync $BR with origin (fast-forward only)"
git fetch origin --quiet
if git rev-parse --verify --quiet "origin/$BR" >/dev/null; then
  git merge --ff-only "origin/$BR" || {
    echo "error: local '$BR' has diverged from origin/$BR." >&2
    echo "       Every deploy adds a 'release:' commit — deploy from ONE machine, or reconcile" >&2
    echo "       (git pull --rebase) before retrying." >&2
    exit 1
  }
fi

run_candidate_audit() {
  if [ "${AIOS_SKIP_POST_DEPLOY_AUDIT:-0}" = "1" ]; then
    echo "==> browser release gates explicitly skipped (AIOS_SKIP_POST_DEPLOY_AUDIT=1)"
    return
  fi
  echo "==> pre-promotion candidate SPA audit (isolated data + port)"
  node bin/candidate-spa-audit.mjs
}

# Exact-SHA deploy (autonomous pipeline — docs/specs/autonomous-deploy-plan.md step 1). When AIOS_DEPLOY_SHA
# is set, the caller (the integration state machine) already prepared + bumped + TESTED that exact candidate
# commit; here we ONLY fast-forward main to it — NO re-bump, NO other mutation — then push + restart. The
# candidate must be a fast-forward descendant of main (never a divergent/force move). Env-gated, so a normal
# `bin/deploy` (no env) is byte-identical to before.
if [ -n "${AIOS_DEPLOY_SHA:-}" ]; then
  SHA="$AIOS_DEPLOY_SHA"
  git rev-parse --verify --quiet "$SHA^{commit}" >/dev/null || { echo "error: AIOS_DEPLOY_SHA is not a commit: $SHA" >&2; exit 1; }
  git merge-base --is-ancestor "$BR" "$SHA" 2>/dev/null || { echo "error: '$BR' is not an ancestor of $SHA — refusing a non-fast-forward exact deploy." >&2; exit 1; }
  echo "==> exact-SHA deploy: fast-forwarding $BR to $(git rev-parse --short "$SHA")"
  git merge --ff-only "$SHA"
  run_candidate_audit
  # Bump the version ON TOP of the deployed candidate so the served version MOVES and the new-version toast
  # fires for autonomous deploys too. bin/version is the only version editor; this release commit only touches
  # package.json/lock (the candidate stays the exact tested code). Verify (src/publisher.js) checks the
  # candidate is an ANCESTOR of the served HEAD, so this one trusted extra commit is expected.
  NEW="$(bin/version "$LEVEL")"
  echo "    -> v$NEW ($(git rev-parse --short HEAD)) — candidate $(git rev-parse --short "$SHA")"
else
  run_candidate_audit
  OLD="$(node -p "require('./package.json').version")"
  echo "==> bump release version ($LEVEL)"
  NEW="$(bin/version "$LEVEL")"
  if [ "$NEW" = "$OLD" ]; then
    echo "error: deploy did not change the release version (still v$NEW)." >&2
    echo "       Use patch/minor/major or a new explicit X.Y.Z; every deploy must move the served version." >&2
    exit 1
  fi
  echo "    -> v$NEW"
fi

# Headless GitHub auth — SELF-HEALING (2026-07-13). Agent shells have no terminal for a username
# prompt and no usable keychain; the push authenticates via a repo-local credential helper that
# reads GITHUB_PAT_AIOS from ~/.dev.vars at push time. If the helper is missing (fresh clone,
# stripped .git/config), re-install it here so a plain `git push` NEVER regresses to "Device not
# configured". Agents: a push failure here means the TOKEN is bad — not that pushing is impossible.
if ! printf 'protocol=https\nhost=github.com\n\n' | git credential fill 2>/dev/null | grep -q '^password=.'; then
  echo "==> installing repo-local GitHub credential helper (reads GITHUB_PAT_AIOS from ~/.dev.vars)"
  git config credential.helper '!f() { test "$1" = get || return 0; printf "username=x-access-token\npassword=%s\n" "$(sed -n "s/^\(export \)\{0,1\}GITHUB_PAT_AIOS=//p" "$HOME/.dev.vars" | head -1 | tr -d \")"; }; f'
fi

echo "==> git push origin $BR (with tags)"
git push origin "$BR" --follow-tags

if [ "$ON_HOST" = 1 ]; then
  # On host itself: the local checkout already has the pushed commit; just refresh deps + restart.
  echo "==> on-host (host): npm install + restart locally"
  npm install --omit=dev
  launchctl kickstart -k "gui/$(id -u)/ai.aios.server" \
    && echo restarted \
    || echo "service not installed — run bin/install-service"
else
  echo "==> host: fetch + fast-forward $BR + npm install"
  ssh "$HOST" "bash -lc 'set -e; cd ~/aios && git fetch origin --quiet && git checkout --quiet \"$BR\" && git merge --ff-only \"origin/$BR\" && npm install --omit=dev'"

  echo "==> restart service"
  ssh "$HOST" 'launchctl kickstart -k "gui/$(id -u)/ai.aios.server" 2>/dev/null \
    && echo restarted \
    || echo "service not installed — run ~/aios/bin/install-service on host"'
fi

# The browser audit is part of the release boundary, not an optional memory-based follow-up. It drives the
# freshly restarted production build through the real SPA/session routes and fails the deploy command on
# document reloads, duplicate shells, view-init exceptions, or broken launch/kill transitions. It uses CDP
# directly and therefore remains available after the production `npm install --omit=dev`.
if [ "${AIOS_SKIP_POST_DEPLOY_AUDIT:-0}" != "1" ]; then
  VERIFY_URL="${AIOS_VERIFY_URL:-http://127.0.0.1:8793/aios/}"
  echo "==> post-deploy production SPA audit ($VERIFY_URL)"
  if [ "$ON_HOST" = 1 ]; then
    node bin/spa-audit.mjs "$VERIFY_URL"
  else
    ssh "$HOST" "bash -lc 'cd ~/aios && node bin/spa-audit.mjs \"$VERIFY_URL\"'"
  fi
fi

echo "==> deployed v$NEW"
