{
  "$comment": "v2 — Machine-checkable spec for story view. verify_story_view.mjs asserts these against the LIVE implementation. Values are exact — not suggestions. v2 adds: title-row contract, icon tints, paddings, shot border, timestamp style; the verifier now also rejects pre-opened expanders and accordion behavior.",
  "domContract": {
    "$comment": "Required data attributes / hooks. The implementation MUST render these; the verifier and future tests key off them.",
    "toggle": "[data-story-toggle]",
    "toggleStory": "[data-story-toggle] [data-mode=story]",
    "toggleTerminal": "[data-story-toggle] [data-mode=terminal]",
    "panel": "[data-story-panel]",
    "rollup": "[data-story-rollup]",
    "event": "[data-story-ev]",
    "eventKindAttr": "data-kind",
    "kinds": ["you", "sys", "work", "plan", "note", "sub", "edit", "fail", "check", "ship", "web", "report", "ask", "stop", "gap"],
    "titleRow": "[data-story-ev] .story-title-row",
    "stepsExpander": "[data-story-steps-toggle]",
    "stepsBody": "[data-story-steps]",
    "askOptions": "[data-story-ask-opt]",
    "shotThumb": "[data-story-shot]"
  },
  "computedStyles": {
    "$comment": "Asserted via getComputedStyle. Tolerance: colors ±1/channel (alpha ±0.02), sizes ±0.5px. The verifier opens one steps expander itself before this pass — do NOT pre-open any.",
    "[data-story-panel]": { "backgroundColor": "#0c1118", "borderColor": "#1d2632", "borderRadius": "13px" },
    "[data-story-rollup]": { "fontFamily": "JetBrains Mono", "fontSize": "10.5px", "color": "#5c6675" },
    "[data-story-ev] .story-title": { "fontSize": "13.5px", "fontWeight": "600", "color": "#e9eef5", "fontFamily": "IBM Plex Sans" },
    "[data-story-ev] .story-ts": { "fontFamily": "JetBrains Mono", "fontSize": "10px", "color": "#3a4453" },
    "[data-story-ev] .story-body": { "fontSize": "13px", "lineHeight": "1.7", "fontFamily": "IBM Plex Sans" },
    "[data-story-ev='you'] .story-body": { "backgroundColor": "#10151d", "borderColor": "#1d2632", "borderRadius": "12px", "color": "#dde5ee", "padding": "11px 14px" },
    "[data-story-ev] .story-icon": { "width": "30px", "height": "30px", "borderRadius": "99px", "fontFamily": "JetBrains Mono", "fontSize": "13px" },
    "[data-story-ev='edit'] .story-icon": { "backgroundColor": "rgba(217, 146, 78, 0.08)", "borderColor": "rgba(217, 146, 78, 0.27)", "color": "#d9924e" },
    "[data-story-ev='ask'] .story-card": { "backgroundColor": "rgba(226, 178, 62, 0.05)", "borderColor": "rgba(226, 178, 62, 0.25)", "borderRadius": "12px", "padding": "13px 15px" },
    "[data-story-ev='ask'] .story-title": { "color": "#e2b23e" },
    "[data-story-ev='fail'] .story-title": { "color": "#f2554d" },
    "[data-story-ask-opt]": { "height": "38px", "borderRadius": "10px", "fontFamily": "JetBrains Mono", "fontSize": "12px", "fontWeight": "700" },
    "[data-story-steps-toggle]": { "fontFamily": "JetBrains Mono", "fontSize": "11px", "color": "#5c6675", "cursor": "pointer" },
    "[data-story-steps] .story-step": { "fontSize": "12.5px", "color": "#8a95a5" },
    "[data-story-steps] .story-cmd": { "fontFamily": "JetBrains Mono", "fontSize": "10.5px", "color": "#5c6675" },
    "[data-story-shot]": { "width": "132px", "height": "82px", "borderRadius": "8px", "borderColor": "#232c38" },
    "[data-mode=story].active, [data-mode=terminal].active": { "color": "#79b8ff", "backgroundColor": "rgba(88, 166, 255, 0.08)" }
  },
  "layout": {
    "iconColumnWidth": 30, "iconContentGap": 14, "blockBottomPadding": 22,
    "subIndent": 42, "feedPadding": [20, 26], "headerStripPadding": [11, 20],
    "toggleChipHeight": 30, "toggleChipRadius": 8, "toggleGap": 5
  },
  "behavior": {
    "$comment": "Enforced by the verifier's interaction pass.",
    "initialStepsCollapsed": true,
    "independentExpanders": true,
    "askPostsToInputEndpoint": true,
    "logViewPersistsAcrossReload": true,
    "dividerFreeDrag": "the terminal/right-panel divider is free drag (fraction persisted) — no min/max clamp; NOT asserted by the verifier, do not regress it"
  },
  "glyphs": { "you": "❯", "sys": "○", "work": "⌕", "plan": "☑", "note": "·", "sub": "⑂", "edit": "✎", "fail": "✗", "check": "✓", "ship": "⬆", "web": "⌾", "report": "≡", "ask": "?", "stop": "⏹" },
  "colors": { "you": "#58a6ff", "sys": "#3a4453", "work": "#8a95a5", "plan": "#79b8ff", "note": "#5c6675", "sub": "#9aa7b8", "edit": "#d9924e", "fail": "#f2554d", "check": "#4ecb6c", "ship": "#2fd6be", "report": "#b9c4d4", "ask": "#e2b23e", "stop": "#e2b23e" }
}
